---

<section class="section-gap mb-8" id="CTA" data-fade>
  <div class="border-2 border-gray-900 bg-white">
    <!-- Top bar -->
    <div class="bg-gray-900 px-6 py-2 flex items-center gap-2">
      <span class="w-3 h-3 rounded-full bg-red-400"></span>
      <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
      <span class="w-3 h-3 rounded-full bg-green-400"></span>
    </div>

    <!-- Body -->
    <div class="px-8 py-10 flex flex-col md:flex-row md:items-center gap-10">
      <!-- Left: hook -->
      <div class="flex-1">
        <p
          class="text-xs font-mono uppercase tracking-[0.2em] text-gray-400 mb-3"
        >
          — open to work
        </p>
        <h2 class="text-4xl font-black leading-tight text-gray-900 mb-0">
          Have a project<br />in mind?
        </h2>
        <div class="mt-4 w-12 h-1 bg-gray-900"></div>
        <p class="mt-4 text-gray-500 text-sm leading-relaxed max-w-xs">
          Let's build something together. Drop a message and I'll get back to
          you.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href="mailto:dhruv.rajak2002@gmail.com"
            class="inline-flex items-center gap-2 bg-gray-900 text-white text-sm font-bold px-5 py-3 no-underline hover:bg-gray-700 transition-colors"
          >
            Get in touch
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href="/resume.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-white text-gray-900 text-sm font-bold px-5 py-3 no-underline border-2 border-gray-900 hover:bg-gray-900 hover:text-white transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            View Resume
          </a>
        </div>
      </div>

      <!-- Divider -->
      <div class="hidden md:block w-px self-stretch bg-gray-200"></div>
      <div class="block md:hidden h-px w-full bg-gray-200"></div>

      <!-- Right: links -->
      <div class="flex flex-col gap-1">
        {
          links.map((link) => (
            <a
              href={link.href}
              target={link.href.startsWith("mailto") ? undefined : "_blank"}
              rel="noopener noreferrer"
              class="group flex items-center gap-3 px-4 py-3 border border-transparent hover:border-gray-900 hover:bg-gray-50 transition-all no-underline"
            >
              <span
                class="text-gray-400 group-hover:text-gray-900 transition-colors shrink-0"
                set:html={link.icon}
              />
              <div class="flex flex-col">
                <span class="text-xs font-mono text-gray-400 uppercase tracking-widest">
                  {link.label}
                </span>
                <span class="text-sm font-medium text-gray-800">
                  {link.display}
                </span>
              </div>
              <svg
                class="ml-auto opacity-0 group-hover:opacity-100 transition-opacity text-gray-900"
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <>
                  <path d="M7 7h10v10" />
                  <path d="M7 17 17 7" />
                </>
              </svg>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
