---
interface Tech {
  name: string;
  icon: string;
  url: string;
}

interface Department {
  label: string;
  techs: Tech[];
}

const departments: Department[] = [
  {
    label: "Frontend",
    techs: [
      {
        name: "React",
        icon: "/images/svg/frontend/react.svg",
        url: "https://react.dev/",
      },
      {
        name: "Expo",
        icon: "/images/svg/frontend/expo.svg",
        url: "https://expo.dev/",
      },
      { name: "Astro",        icon: "/images/svg/frontend/astro.svg",        url: "https://astro.build/" },
      { name: "Tailwind CSS", icon: "/images/svg/frontend/tailwindcss.svg",  url: "https://tailwindcss.com/" },
      { name: "Zustand",      icon: "/images/svg/frontend/zustand.svg",      url: "https://zustand-demo.pmnd.rs/" },
    ],
  },
  {
    label: "Backend",
    techs: [
      { name: "Node.js",             icon: "/images/svg/backend/node.svg",      url: "https://nodejs.org/" },
      { name: "Express",             icon: "/images/svg/backend/expressjs.svg",  url: "https://expressjs.com/" },
      { name: "tRPC",                icon: "/images/svg/backend/tRPC.svg",       url: "https://trpc.io/" },
      { name: "PostgreSQL",          icon: "/images/svg/backend/postgres.svg",   url: "https://www.postgresql.org/" },
      { name: "MongoDB",             icon: "/images/svg/backend/mongoDB.svg",    url: "https://www.mongodb.com/" },
      { name: "Redis",               icon: "/images/svg/backend/redis.svg",      url: "https://redis.io/" },
      { name: "SQLite",              icon: "/images/svg/backend/sqlite.svg",     url: "https://www.sqlite.org/" },
      { name: "Firebase",            icon: "/images/svg/backend/firebase.svg",   url: "https://firebase.google.com/" },
      { name: "DynamoDB",            icon: "/images/svg/backend/dynamoDB.svg",   url: "https://aws.amazon.com/dynamodb/" },
      { name: "Amazon Web Services", icon: "/images/svg/backend/aws.svg",        url: "https://aws.amazon.com/" },
    ],
  },
  {
    label: "Languages",
    techs: [
      { name: "TypeScript", icon: "/images/svg/languages/typescript.svg", url: "https://www.typescriptlang.org/" },
      { name: "JavaScript", icon: "/images/svg/languages/javascript.svg", url: "https://developer.mozilla.org/en-US/docs/Web/JavaScript" },
      { name: "Go",         icon: "/images/svg/languages/golang.svg",     url: "https://go.dev/" },
      { name: "HTML",       icon: "/images/svg/languages/html.svg",       url: "https://developer.mozilla.org/en-US/docs/Web/HTML" },
      { name: "Bash",       icon: "/images/svg/languages/bash.svg",       url: "https://www.gnu.org/software/bash/" },
    ],
  },
  {
    label: "Tools",
    techs: [
      { name: "Git",     icon: "/images/svg/tools/git.svg",    url: "https://git-scm.com/" },
      { name: "pnpm",    icon: "/images/svg/tools/pnpm.svg",   url: "https://pnpm.io/" },
      { name: "Biome",   icon: "/images/svg/tools/biome.svg",  url: "https://biomejs.dev/" },
      { name: "Vite",    icon: "/images/svg/tools/vite.svg",   url: "https://vite.dev/" },
      { name: "VS Code", icon: "/images/svg/tools/vscode.svg", url: "https://code.visualstudio.com/" },
    ],
  },
];
---

<section class="mt-24">
  <h2 class="text-2xl font-bold mb-8 text-gray-800">Tech Stack</h2>

  <div class="flex flex-col gap-8">
    {
      departments.map((dept) => (
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-400 mb-4">
            {dept.label}
          </h3>
          <div class="flex flex-wrap gap-3">
            {dept.techs.map((tech) => (
              <a
                href={tech.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 px-3 py-2 rounded-lg border border-gray-200 bg-white shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 no-underline"
              >
                <img
                  src={tech.icon}
                  alt={tech.name}
                  class="w-6 h-6 object-contain shrink-0"
                  loading="lazy"
                />
                <span class="text-sm font-medium text-gray-700 whitespace-nowrap">
                  {tech.name}
                </span>
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
