---
const year = new Date().getFullYear();

const socials = [
  {
    label: "GitHub",
    href: "https://github.com/Varchronos",
    copy: "https://github.com/Varchronos",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.021c0 4.428 2.865 8.184 6.839 9.504.5.092.682-.217.682-.482 0-.237-.009-.868-.014-1.703-2.782.605-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.026 2.747-1.026.546 1.378.202 2.397.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.2 22 16.447 22 12.021 22 6.484 17.523 2 12 2z"/></svg>`,
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/dhruv-rajak-4669341bb/",
    copy: "https://www.linkedin.com/in/dhruv-rajak-4669341bb/",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>`,
  },
  {
    label: "X / Twitter",
    href: "https://x.com/dhruv0b",
    copy: "https://x.com/dhruv0b",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622 5.91-5.622Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
  {
    label: "Email",
    href: "mailto:dhruv.rajak2002@gmail.com",
    copy: "dhruv.rajak2002@gmail.com",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  },
];

const copyIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>`;
const checkIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
---

<footer class="border-t-2 border-black mt-8">
  <div class="max-w-7xl mx-auto px-6 py-8 flex flex-col md:flex-row items-center justify-between gap-6">

    <!-- Left: name + copyright -->
    <div class="flex flex-col gap-1">
      <span class="font-mono font-black text-sm uppercase tracking-widest text-black">Dhruv Rajak</span>
      <span class="font-mono text-xs text-gray-500">&copy; {year} — All rights reserved.</span>
    </div>

    <!-- Right: social rows with copy -->
    <div class="flex flex-col gap-1">
      {socials.map((s) => (
        <div class="flex items-center gap-0 border-2 border-transparent hover:border-black transition-colors group">
          <!-- Icon + label link -->
          <a
            href={s.href}
            target={s.href.startsWith("mailto") ? undefined : "_blank"}
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-3 py-1.5 no-underline text-black"
          >
            <span set:html={s.icon} />
            <span class="font-mono text-xs font-bold uppercase tracking-wide">{s.label}</span>
          </a>

          <!-- Copy button -->
          <button
            class="copy-btn ml-auto px-2 py-1.5 border-l-2 border-transparent group-hover:border-black text-gray-400 hover:bg-black hover:text-white transition-colors cursor-pointer bg-transparent"
            data-copy={s.copy}
            aria-label={`Copy ${s.label}`}
            set:html={copyIcon}
          />
        </div>
      ))}
    </div>

  </div>
</footer>

<!-- Toast -->
<div id="copy-toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 hidden font-mono text-xs font-black uppercase tracking-widest bg-black text-white px-4 py-2 border-2 border-black" style="box-shadow: 3px 3px 0 #666;">
  Copied!
</div>

<script>
  const toast = document.getElementById('copy-toast')!;
  let toastTimer: ReturnType<typeof setTimeout> | null = null;

  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy!;
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        // fallback
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }

      // swap to check icon briefly
      const orig = btn.innerHTML;
      btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
      setTimeout(() => { btn.innerHTML = orig; }, 1500);

      // show toast
      if (toastTimer) clearTimeout(toastTimer);
      toast.classList.remove('hidden');
      toastTimer = setTimeout(() => toast.classList.add('hidden'), 1800);
    });
  });
</script>
