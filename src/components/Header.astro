---
import { SITE_TITLE } from '../consts';
---

<nav class="bg-white fixed w-full z-20 top-0 border-b-2 border-black">
  <div class="max-w-7xl flex flex-wrap items-center justify-between mx-auto px-6 py-3">

    <a href="/" class="no-underline flex items-center gap-2">
      <img src="/favicon-32x32.png" alt="Dhruv Rajak" class="w-8 h-8 border-2 border-black" style="border-radius:0; image-rendering: pixelated;" />
      <span class="font-mono font-black text-base uppercase tracking-widest text-black">
        {SITE_TITLE}
      </span>
    </a>

    <!-- Burger (mobile) -->
    <button
      id="burger-btn"
      type="button"
      aria-controls="navbar-menu"
      aria-expanded="false"
      class="inline-flex items-center justify-center p-2 w-10 h-10 text-black border-2 border-black md:hidden hover:bg-black hover:text-white transition-colors"
    >
      <span class="sr-only">Open main menu</span>
      <svg id="icon-burger" class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
      </svg>
      <svg id="icon-close" class="w-5 h-5 hidden" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
      </svg>
    </button>

    <!-- Nav links + actions -->
    <div id="navbar-menu" class="hidden w-full md:flex md:items-center md:gap-2 md:w-auto">
      <!-- Page links -->
      <ul class="flex flex-col md:flex-row mt-4 md:mt-0 border-2 border-black md:border-none bg-white p-1 md:p-0">
        <li>
          <a href="/" class="block px-4 py-1.5 font-mono font-bold text-sm uppercase tracking-wider text-black no-underline hover:bg-black hover:text-white transition-colors">
            Home
          </a>
        </li>
        {/* Blog and About hidden for now */}
        <!-- <li>
          <a href="/blog" class="block px-4 py-1.5 font-mono font-bold text-sm uppercase tracking-wider text-black no-underline hover:bg-black hover:text-white transition-colors">
            Blog
          </a>
        </li>
        <li>
          <a href="/about" class="block px-4 py-1.5 font-mono font-bold text-sm uppercase tracking-wider text-black no-underline hover:bg-black hover:text-white transition-colors">
            About
          </a>
        </li> -->
      </ul>

      <!-- Divider -->
      <div class="hidden md:block w-px h-6 bg-black mx-2"></div>

      <!-- Social icons -->
      <div class="flex items-center gap-1 mt-3 md:mt-0">
        <a href="https://github.com/Varchronos" target="_blank" rel="noopener noreferrer" aria-label="GitHub"
          class="p-2 border-2 border-transparent hover:border-black hover:bg-black hover:text-white text-black transition-colors no-underline">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.021c0 4.428 2.865 8.184 6.839 9.504.5.092.682-.217.682-.482 0-.237-.009-.868-.014-1.703-2.782.605-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.026 2.747-1.026.546 1.378.202 2.397.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.2 22 16.447 22 12.021 22 6.484 17.523 2 12 2z"/>
          </svg>
        </a>
        <a href="https://www.linkedin.com/in/dhruv-rajak-4669341bb/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"
          class="p-2 border-2 border-transparent hover:border-black hover:bg-black hover:text-white text-black transition-colors no-underline">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
        <a href="https://x.com/dhruv0b" target="_blank" rel="noopener noreferrer" aria-label="X / Twitter"
          class="p-2 border-2 border-transparent hover:border-black hover:bg-black hover:text-white text-black transition-colors no-underline">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622 5.91-5.622Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      </div>

      <!-- Divider -->
      <div class="hidden md:block w-px h-6 bg-black mx-2"></div>

      <!-- Resume -->
      <a
        href="/resume.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-3 md:mt-0 font-mono font-black text-xs uppercase tracking-wider px-4 py-2 bg-white text-black border-2 border-black hover:bg-black hover:text-white transition-colors no-underline flex items-center gap-1.5"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Resume
      </a>

      <!-- Get in touch -->
      <button
        id="cta-btn"
        class="mt-3 md:mt-0 font-mono font-black text-xs uppercase tracking-wider px-4 py-2 bg-black text-white border-2 border-black hover:bg-white hover:text-black transition-colors cursor-pointer"
        style="box-shadow: 3px 3px 0 #666;"
      >
        Get in touch
      </button>
    </div>

  </div>
</nav>

<script>
  const btn = document.getElementById('burger-btn')!;
  const menu = document.getElementById('navbar-menu')!;
  const iconBurger = document.getElementById('icon-burger')!;
  const iconClose = document.getElementById('icon-close')!;

  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    iconBurger.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  document.getElementById('cta-btn')?.addEventListener('click', () => {
    const cta = document.getElementById('CTA');
    if (!cta) return;
    cta.scrollIntoView({ behavior: 'smooth' });
    // glow effect
    cta.classList.add('cta-glow');
    setTimeout(() => cta.classList.remove('cta-glow'), 1800);
  });
</script>

<style>
  @keyframes ctaGlow {
    0%   { box-shadow: 0 0 0 0 rgba(255,215,0,0); outline: 3px solid transparent; }
    20%  { box-shadow: 0 0 28px 10px rgba(255,215,0,0.5); outline: 3px solid #FFD700; }
    80%  { box-shadow: 0 0 28px 10px rgba(255,215,0,0.5); outline: 3px solid #FFD700; }
    100% { box-shadow: 0 0 0 0 rgba(255,215,0,0); outline: 3px solid transparent; }
  }
  :global(.cta-glow) {
    animation: ctaGlow 1.8s ease forwards;
  }
</style>
