---
import "../styles/global.css";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import ProjectShowcase from "../components/home/ProjectShowcase.astro";
import TechStackShowcase from "../components/home/TechStackShowcase.astro";
import CTASection from "../components/home/CTASection.astro";
import GithubStats from "../components/home/GithubStats.astro";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="landing">
				<div class="landing-left">
					<p class="brut-label mb-2">Software Engineer</p>
					<h4 class="-mb-1 font-mono font-black uppercase tracking-tight">Hi, I am Dhruv</h4>
					<p class="subheading">
						a&nbsp;<span class="word-cycle">
							<span class="word word-1">Fullstack Developer</span>
							<span class="word word-2">Mobile App Developer</span
							>
							<span class="word word-3">Software Engineer</span>
						</span>
					</p>
					<p class="mt-4 text-base text-gray-600 leading-relaxed max-w-lg">
						Expertise in <span class="font-bold text-black">web</span> and
						<span class="font-bold text-black">cross-platform app development</span>.
						Focused on <span class="font-bold text-black">scalable</span> software, User Experience and Business Requirements.
					</p>
					<p class="-mt-2 text-base text-gray-600 leading-relaxed">
						Lets look at some of my <button
							id="scroll-to-projects"
							class="font-mono font-black text-black border-b-2 border-black bg-transparent hover:bg-black hover:text-white px-1 transition-colors cursor-pointer"
							>projects ↓</button
						>.
					</p>
				</div>
				<div class="landing-right">
					<GithubStats />
				</div>
			</section>
			<ProjectShowcase />
			<TechStackShowcase />
			<CTASection />
		</main>
		<Footer />
	</body>
</html>

<script>
  document.getElementById("scroll-to-projects")?.addEventListener("click", () => {
    document.getElementById("projects")?.scrollIntoView({ behavior: "smooth" });
  });
</script>

<style>
	.landing {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 5rem;
		align-items: center;
		padding-top: 2em;
	}

	.landing-left {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}

	.landing-right {
		width: 280px;
		flex-shrink: 0;
	}

	@media (max-width: 768px) {
		.landing {
			grid-template-columns: 1fr;
		}
		.landing-right {
			width: 100%;
		}
	}

	.subheading {
		font-size: 1.5em;
		display: flex;
		align-items: baseline;
		margin: 0;
	}

	/* Grid trick: all words occupy the same cell so the container
	   naturally sizes to the widest word — no fixed width needed. */
	.word-cycle {
		display: inline-grid;
		overflow: hidden;
		height: 1.4em;
		line-height: 1.4em;
		vertical-align: bottom;
	}

	.word {
		grid-area: 1 / 1;
		opacity: 0;
		transform: translateY(-100%);
		animation: cycleWord 9s infinite;
	}

	/* Each word is active for 3 s out of every 9 s cycle.
	   0 %  → 0.5 s  : fade in from above
	   0.5 s → 2.5 s  : hold
	   2.5 s → 3 s   : fade out downward
	   3 s  → 9 s   : hidden (other words showing) */
	@keyframes cycleWord {
		0% {
			opacity: 0;
			transform: translateY(-100%);
		}
		5.56% {
			opacity: 1;
			transform: translateY(0);
		}
		27.78% {
			opacity: 1;
			transform: translateY(0);
		}
		33.33% {
			opacity: 0;
			transform: translateY(100%);
		}
		33.34%,
		100% {
			opacity: 0;
			transform: translateY(-100%);
		}
	}

	.word-1 {
		animation-delay: 0s;
		color: #4f46e5;
		font-weight: 900;
	}
	.word-2 {
		animation-delay: 3s;
		color: #0369a1;
		font-weight: 900;
	}
	.word-3 {
		animation-delay: 6s;
		color: #b45309;
		font-weight: 900;
	}
</style>
